# Application
APP_PORT=8080
APP_ENV=development
APP_BASE_URL=http://localhost:8080
SERVICE_NAME=post-pilot-api

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_SOURCE=true

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=post_pilot
DB_SSLMODE=disable

# Migrator service
MIGRATIONS_PATH=packages/database/migrations
ALLOW_DESTRUCTIVE_MIGRATIONS=false

# JWT and auth crypto
JWT_ACCESS_SECRET_KEY=change-me-access-secret-min-32-bytes-long
JWT_REFRESH_SECRET_KEY=change-me-refresh-secret-min-32-bytes-long
JWT_EXPIRY=3600
JWT_REFRESH_EXPIRY=604800
BCRYPT_COST=12

# Auth rate limiting
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_REGISTER_RATE_LIMIT_MAX=5
AUTH_REFRESH_RATE_LIMIT_MAX=20

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Redis cache/session/rate-limit backend
REDIS_ADDR=localhost:6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE=2
REDIS_DIAL_TIMEOUT=3s
REDIS_READ_TIMEOUT=2s
REDIS_WRITE_TIMEOUT=2s
REDIS_POOL_TIMEOUT=4s
REDIS_CONN_MAX_IDLE=5m
REDIS_CONN_MAX_LIFE=30m
REDIS_MAX_RETRIES=3
REDIS_MIN_RETRY_BACKOFF=100ms
REDIS_MAX_RETRY_BACKOFF=2s
REDIS_TLS_ENABLED=false
REDIS_TLS_INSECURE_SKIP_VERIFY=false
